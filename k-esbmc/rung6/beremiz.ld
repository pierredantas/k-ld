TON(TON1_Q, 2, XIO(ORANGE_LIGHT)) ;
TON(TON2_Q, 2, XIC(ORANGE_LIGHT)) ;
OTU(ORANGE_LIGHT) := XIC(R_TRIG0_Q) ;
OTL(ORANGE_LIGHT) := XIC(R_TRIG1_Q) ;
OTE(R_TRIG0_clk) := XIC(TON2_Q) ;
OTE(R_TRIG0_Q) := XIC(R_TRIG0_clk) * XIO(prev_R_TRIG0) ;
OTE(R_TRIG1_clk) := XIC(TON1_Q) ;
OTE(R_TRIG1_Q) := XIC(R_TRIG1_clk) * XIO(prev_R_TRIG1) ;
OTE(prev_R_TRIG0) := XIC(R_TRIG0_clk) ;
OTE(prev_R_TRIG1) := XIC(R_TRIG1_clk) ;
