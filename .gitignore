# Paper sources and its CI are intentionally NOT part of this artifact repo.
/ACM/
/.github/

# K build outputs (regenerated by kompile / kprove)
k-ld/ld-kompiled/
k-ld/ld-haskell/
k-ld/rung6/gen/
k-ld/**/.kompile-*
k-ld/**/.krun-*
k-ld/**/.kprove-*

# E4 generated mutants and run logs (regenerated by mutate.py / run_*.py)
k-ld/rung7/mut_*/
k-ld/rung7/*.log

# Python / OS cruft
**/__pycache__/
*.pyc
.DS_Store

# Large / transient
*.tar.gz
