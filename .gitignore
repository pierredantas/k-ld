# E4 generated mutants and run logs (regenerated by mutate.py / run_*.py)
k-esbmc/rung7/mut_*/
k-esbmc/rung7/*.log

# Python / OS cruft
**/__pycache__/
*.pyc
.DS_Store

# Large / transient
*.tar.gz
